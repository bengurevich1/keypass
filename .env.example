# Database
DB_PASSWORD=keypass123

# JWT Secrets
JWT_SECRET=your-super-secret-jwt-key-change-me
JWT_REFRESH_SECRET=your-super-secret-refresh-key-change-me

# Super Admin (created on first run)
SUPER_ADMIN_EMAIL=admin@keypass.co.il
SUPER_ADMIN_PASSWORD=admin123456

# WhatsApp (Meta Business API — leave empty for DEV_MODE console logging)
WHATSAPP_TOKEN=your-meta-api-token
WHATSAPP_PHONE_ID=your-phone-number-id

# WhatsApp Template for registration invites (REQUIRED for sending)
# Create/manage at: https://business.facebook.com/wa/manage/message-templates/
WHATSAPP_TEMPLATE_NAME=keypass_invite
WHATSAPP_TEMPLATE_LANG=he
# WHATSAPP_TEMPLATE_PARAMS: 2 = {{1}}=name, {{2}}=link | 3 = {{1}}=name, {{2}}=org, {{3}}=link
WHATSAPP_TEMPLATE_PARAMS=3

# Dev Mode (true = WhatsApp messages logged to console, not sent)
DEV_MODE=true

# Base URL (for registration links sent in WhatsApp)
BASE_URL=http://localhost:3000

# APK file path (for /download endpoint)
APK_PATH=./public/KeyPass.apk

# CORS Origins
CORS_ORIGINS=http://localhost:5173,http://localhost:5174
