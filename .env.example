# Database
DB_PASSWORD=keypass123

# JWT Secrets
JWT_SECRET=your-super-secret-jwt-key-change-me
JWT_REFRESH_SECRET=your-super-secret-refresh-key-change-me

# Super Admin (created on first run)
SUPER_ADMIN_EMAIL=admin@keypass.co.il
SUPER_ADMIN_PASSWORD=admin123456

# WhatsApp (Meta Business API — leave empty for DEV_MODE console logging)
WHATSAPP_TOKEN=your-meta-api-token
WHATSAPP_PHONE_ID=your-phone-number-id

# WhatsApp Template for registration invites (REQUIRED for sending)
# Create/manage at: https://business.facebook.com/wa/manage/message-templates/
WHATSAPP_TEMPLATE_NAME=keypass_invite
WHATSAPP_TEMPLATE_LANG=he
# WHATSAPP_TEMPLATE_PARAMS: 2 = {{1}}=name, {{2}}=link | 3 = {{1}}=name, {{2}}=org, {{3}}=link
WHATSAPP_TEMPLATE_PARAMS=3

# Dev Mode (true = WhatsApp messages logged to console, not sent)
DEV_MODE=true

# Base URL (for registration links sent in WhatsApp)
BASE_URL=http://localhost:3000

# APK file path (for /download endpoint)
APK_PATH=./public/KeyPass.apk

# CORS Origins
CORS_ORIGINS=http://localhost:5173,http://localhost:5174

# ─── Google Wallet (optional — leave empty to disable) ───
# 1. Create a GCP project, enable walletobjects.googleapis.com
# 2. Create a service account, download JSON key to backend/secrets/google-wallet-sa.json
# 3. Sign up at https://pay.google.com/business/console, copy your Issuer ID
# 4. Invite the SA email as a Developer in the Wallet console
GOOGLE_WALLET_ISSUER_ID=
GOOGLE_WALLET_SA_KEY_PATH=./secrets/google-wallet-sa.json
# Alternatively, paste raw JSON here (used only if SA_KEY_PATH is empty)
GOOGLE_WALLET_SA_KEY_JSON=
GOOGLE_WALLET_CLASS_SUFFIX=keypass_membership_v1

# ─── Apple Wallet (optional — requires $99/yr Apple Developer Program) ───
# 1. Register a Pass Type ID (pass.co.keypass.membership) in developer.apple.com
# 2. Generate the Pass Type Certificate, export from Keychain
# 3. Convert .p12 to .pem files, place in backend/secrets/
APPLE_PASS_TYPE_ID=pass.co.keypass.membership
APPLE_TEAM_ID=
APPLE_PASS_CERT_PATH=./secrets/apple-pass-cert.pem
APPLE_PASS_KEY_PATH=./secrets/apple-pass-key.pem
APPLE_PASS_KEY_PASSPHRASE=
APPLE_WWDR_CERT_PATH=./secrets/AppleWWDRCAG3.pem
APPLE_PASS_MODEL_DIR=./assets/keypass.pass
